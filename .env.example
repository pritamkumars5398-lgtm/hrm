# Copy to `.env` and fill in. Only VITE_-prefixed vars reach the browser bundle —
# never put a secret (client secret, API key, DB URL) in this file. Those belong
# in the backend's own env.

# Google OAuth client ID (public by design — the client *secret* stays server-side).
# Get one at: Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (Web application). Add http://localhost:5173 as an authorised JavaScript origin.
# Until this is set, the Google button falls back to the simulated chooser.
VITE_GOOGLE_CLIENT_ID=

# Base URL of the NestJS backend. Unset in Phase 1 — the app runs on mock services.
# Set this when the auth backend lands, e.g. http://localhost:3000
VITE_API_BASE_URL=
